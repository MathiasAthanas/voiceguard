HOST=0.0.0.0
PORT=8000
VOICEPRINTS_DIR=voiceprints
WEIGHTS_DIR=weights
AASIST_WEIGHTS_URL=
SAMPLE_RATE=16000
# Segment/clip length the model embeds. Raised 3→5: 3 s was too short for stable
# speaker embeddings (esp. on narrowband audio). Pairs with the 8 s on-device
# capture window (ShellAudioSession SEGMENT_SECS / recorder segmentSeconds).
SEGMENT_DURATION=5
# WavLM-Base+ cosine similarity thresholds (calibrated 2026-06-29).
# WavLM similarities are higher than ECAPA-TDNN: same-speaker over cellular
# typically lands 0.80–0.90; different-speaker 0.45–0.65.
# VERIFICATION_THRESHOLD: accept above this → "Likely <contact>"
# VERIFICATION_HIGH_THRESHOLD: accept above this → "Verified — this is <contact>"
# VERIFICATION_LOW_THRESHOLD: reject below this → "Does NOT sound like <contact>"
#   Between LOW and VERIFICATION → "Uncertain — audio quality too low to confirm"
# Recalibrated 2026-06-30 after score-averaging + codec-augmented enrollment.
# Score-averaging across templates lowers ALL scores, but impostors far more:
# real speaker now ~0.77, AI-voice impostor ~0.42–0.45 (33-point gap). Threshold
# moved 0.80→0.68 to sit in that gap — genuine accepted, impostors rejected.
# HIGH 0.90→0.85 so strong genuine segments can still read "Verified".
VERIFICATION_THRESHOLD=0.68
VERIFICATION_HIGH_THRESHOLD=0.85
VERIFICATION_LOW_THRESHOLD=0.55

# ── Speaker model backend ────────────────────────────────────────────────────
# Switch the speaker model here. Debug audio showed verification/enrollment is
# band-limited to ≤4 kHz (telephone narrowband); WavLM is wideband-trained and
# loses same-gender discrimination on it, so a telephone-robust model is the fix.
#   wavlm     = microsoft/wavlm-base-plus-sv (default, 512-dim, wideband).
#   wespeaker = WeSpeaker ResNet34-LM / eRes2Net (telephone-robust). RECOMMENDED
#               for cellular. Requires: pip install git+https://github.com/wenet-e2e/wespeaker.git (pure PyTorch, no
#               NeMo). Set WESPEAKER_MODEL or WESPEAKER_MODEL_DIR below.
#   titanet   = NVIDIA TitaNet-Large (needs pip install nemo_toolkit[asr]).
# Switching backend changes the embedding space — RE-ENROLL all contacts after.
SPEAKER_MODEL=wespeaker

# WeSpeaker model: a pretrained name (e.g. "english") downloaded on first use,
# OR set WESPEAKER_MODEL_DIR to a local model directory. WESPEAKER_EMBEDDING_DIM
# is the stale-voiceprint check hint (ResNet34-LM = 256).
WESPEAKER_MODEL=english
# WESPEAKER_MODEL_DIR=
WESPEAKER_EMBEDDING_DIM=256
# WeSpeaker cosine scale is much lower than WavLM (same-speaker ~0.45–0.65 on
# narrowband). Measured: genuine clean 0.41–0.61, impostors 0.02–0.25.
# Lowered 0.40→0.35 to catch genuine-but-noisy speech (0.36–0.40 band) while
# keeping a ~0.10 margin above the highest impostor (0.25). Known-good fallback
# is 0.40 (see voiceguard_working_baseline memory). Code default 0.40/0.55/0.25.
WESPEAKER_VERIFICATION_THRESHOLD=0.35
WESPEAKER_HIGH_THRESHOLD=0.55
WESPEAKER_LOW_THRESHOLD=0.25

# ── Speech enhancement on verification audio (Fix 3) ─────────────────────────
# Runs DeepFilterNet over codec-degraded VOICE_DOWNLINK audio before embedding,
# to close the clean-enrollment / telephone-test domain gap.
# Requires: pip install deepfilternet. Installed 2026-06-30.
# DISABLED 2026-06-30: denoising inflated AI/cloned-voice similarity (impostors
# scored ~0.68+ vs ~0.42 without it), causing false "Real speaker" results. The
# enhancement scrubs the very artifacts that expose a synthetic voice. Leave off
# unless re-validated against an AI-voice impostor set.
ENABLE_SPEECH_ENHANCEMENT=false

# ── Multi-condition enrollment augmentation (Fix 5) ──────────────────────────
# At enrollment, also store telephone-codec-simulated versions of each sample so
# the stored templates span both clean and cellular domains. No extra deps.
ENABLE_ENROLL_AUGMENTATION=true

# ── Debug: save the audio the model embeds (for listening) ───────────────────
# Writes enrollment + verification samples to DEBUG_AUDIO_DIR/<contact>/ as WAV,
# with the similarity score + verdict in verify filenames. Turn OFF when done.
DEBUG_SAVE_AUDIO=true
DEBUG_AUDIO_DIR=debug_audio
SPOOF_THRESHOLD=0.5
# Anti-spoofing threshold for the CNN+LSTM v2 model.
# Raised from training default (0.20) to 0.32 to reduce false-reject rate
# on real callers. Increase toward 0.45 for stricter spoof detection;
# decrease toward 0.20 to catch more borderline clones at the cost of
# more real callers being flagged.
CNN_LSTM_SPOOF_THRESHOLD=0.32

# Dashboard — set a PIN to enable the login screen (leave empty for open access)
DASHBOARD_PIN=
# SQLite file for persistent dashboard history
DASHBOARD_DB=dashboard.db
