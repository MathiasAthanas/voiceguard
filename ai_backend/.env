HOST=0.0.0.0
PORT=8000
VOICEPRINTS_DIR=voiceprints
WEIGHTS_DIR=weights
AASIST_WEIGHTS_URL=
SAMPLE_RATE=16000
SEGMENT_DURATION=3
# Cosine similarity threshold for phone-microphone audio.
# Studio recordings: 0.75+. Phone/VoIP audio: 0.50-0.65.
VERIFICATION_THRESHOLD=0.55
SPOOF_THRESHOLD=0.5
# Anti-spoofing threshold for the CNN+LSTM v2 model.
# Raised from training default (0.20) to 0.32 to reduce false-reject rate
# on real callers. Increase toward 0.45 for stricter spoof detection;
# decrease toward 0.20 to catch more borderline clones at the cost of
# more real callers being flagged.
CNN_LSTM_SPOOF_THRESHOLD=0.32

# Dashboard — set a PIN to enable the login screen (leave empty for open access)
DASHBOARD_PIN=
# SQLite file for persistent dashboard history
DASHBOARD_DB=dashboard.db
