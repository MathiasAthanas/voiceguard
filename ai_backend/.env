HOST=0.0.0.0
PORT=8000
VOICEPRINTS_DIR=voiceprints
WEIGHTS_DIR=weights
AASIST_WEIGHTS_URL=
SAMPLE_RATE=16000
SEGMENT_DURATION=3
# WavLM-Base+ cosine similarity thresholds (calibrated 2026-06-29).
# WavLM similarities are higher than ECAPA-TDNN: same-speaker over cellular
# typically lands 0.80–0.90; different-speaker 0.45–0.65.
# VERIFICATION_THRESHOLD: accept above this → "Likely <contact>"
# VERIFICATION_HIGH_THRESHOLD: accept above this → "Verified — this is <contact>"
# VERIFICATION_LOW_THRESHOLD: reject below this → "Does NOT sound like <contact>"
#   Between LOW and VERIFICATION → "Uncertain — audio quality too low to confirm"
VERIFICATION_THRESHOLD=0.75
VERIFICATION_HIGH_THRESHOLD=0.90
VERIFICATION_LOW_THRESHOLD=0.55
SPOOF_THRESHOLD=0.5
# Anti-spoofing threshold for the CNN+LSTM v2 model.
# Raised from training default (0.20) to 0.32 to reduce false-reject rate
# on real callers. Increase toward 0.45 for stricter spoof detection;
# decrease toward 0.20 to catch more borderline clones at the cost of
# more real callers being flagged.
CNN_LSTM_SPOOF_THRESHOLD=0.32

# Dashboard — set a PIN to enable the login screen (leave empty for open access)
DASHBOARD_PIN=
# SQLite file for persistent dashboard history
DASHBOARD_DB=dashboard.db
