HOST=0.0.0.0
PORT=8000
VOICEPRINTS_DIR=voiceprints
WEIGHTS_DIR=weights
AASIST_WEIGHTS_URL=
SAMPLE_RATE=16000
SEGMENT_DURATION=3
VERIFICATION_THRESHOLD=0.55
SPOOF_THRESHOLD=0.5
# Anti-spoofing risk threshold for the CNN+LSTM v2 model.
# Results above this become spoof_suspected; repeated evidence is required
# on real callers. Range: 0.20 (permissive) to 0.45 (strict).
CNN_LSTM_SPOOF_THRESHOLD=0.32

# Leave DASHBOARD_PIN empty to disable the dashboard login screen.
DASHBOARD_PIN=
# Path to the SQLite file used for persistent dashboard history.
DASHBOARD_DB=dashboard.db
